rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── DEVELOPMENT MODE ─────────────────────────────────────
    // For the local emulator only, we allow all reads and writes
    // so the system can be seeded and tested easily.
    // In production, these rules MUST be locked down.

    match /campaigns/{campaignId} {
      allow read: if true;  // Anyone can read
      allow write: if true; // Anyone can write (dev only)
    }

    match /liveSessions/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    match /homebrew/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
