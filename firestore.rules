rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campaign Documents ──────────────────────────────────
    // DM (with Firebase Auth custom claim role == "dm") has full read/write.
    // Any authenticated user (anonymous players) can read.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role == "dm";
    }

    // ── Live Session Documents ──────────────────────────────
    // Real-time combat & session state synced to players.
    match /liveSessions/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role == "dm";
    }

    // ── Homebrew Documents ──────────────────────────────────
    // DM writes; any authenticated user can read.
    match /homebrew/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role == "dm";
    }

    // ── Deny access to any other collections ────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
