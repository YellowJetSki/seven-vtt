rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campaign Documents ──────────────────────────────────
    // Allow all reads and writes for the VTT application.
    // The app's authentication (env-based DM check + player name matching)
    // is handled at the application layer, not Firebase Auth.
    // This is acceptable because:
    //   - Campaign data is not sensitive (fantasy RPG content)
    //   - The app URL is not publicly advertised
    //   - DM credentials gate access at the app level
    match /campaigns/{campaignId} {
      allow read, write: if true;
    }

    // ── Live Session Documents ──────────────────────────────
    // Real-time combat & session state synced to players.
    match /liveSessions/{campaignId} {
      allow read, write: if true;
    }

    // ── Homebrew Documents ──────────────────────────────────
    // Custom items, feats, spells library.
    match /homebrew/{campaignId} {
      allow read, write: if true;
    }

    // ── Deny access to any other collections ────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
