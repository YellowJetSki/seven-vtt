{
  "name": "str-vtt-root",
  "private": true,
  "description": "Monorepo root — VTT project lives in /vtt",
  "scripts": {
    "build": "cd vtt && npm run build",
    "dev": "cd vtt && npm run dev",
    "lint": "cd vtt && npm run lint",
    "deploy": "cd vtt && npx vercel --prod",
    "test:unit": "cd vtt && npx vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@fontsource/playfair-display": "^5.3.0",
    "@fontsource/plus-jakarta-sans": "^5.3.0",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
