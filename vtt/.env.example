# === STᚱ VTT Environment Variables ===

# DM Authentication
VITE_DM_USERNAME=MikeJello
VITE_DM_PASSWORD=Jello1

# Firebase Configuration (Required for Firestore sync)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Firebase Emulators (Dev only)
VITE_USE_EMULATORS=false

# Firebase Auth (Production DM Login)
# The DM login form will attempt Firebase Auth sync using these credentials.
# If Firebase is not configured, the app still works fully in offline/localStorage mode.
VITE_FIREBASE_AUTH_EMAIL=dm@arkla.com
VITE_FIREBASE_AUTH_PASSWORD=your-dm-password
