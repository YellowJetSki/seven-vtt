# ─── STᚱ VTT Environment Variable Documentation ────────────────
# Copy this file to .env (without .example extension) and fill in
# your values. DM credentials are required for the app to function.
# Firebase vars are optional — the app works offline without them.
# ────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# REQUIRED — DM Authentication
# ═══════════════════════════════════════════════════════════════
# The username and password the Dungeon Master uses to log in.
# Choose something memorable but not obvious (avoid "dm"/"admin"/"password").
VITE_DM_USERNAME=changeme
VITE_DM_PASSWORD=changeme

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Firebase Configuration
# ═══════════════════════════════════════════════════════════════
# If you want to use Firebase for cloud storage, create a Firebase
# project at https://console.firebase.google.com and fill in the
# values below. If left blank, the app runs entirely in local
# storage mode (data persisted in the browser).

# Your Firebase project's API key
VITE_FIREBASE_API_KEY=

# Your Firebase project's auth domain (e.g., "my-project.firebaseapp.com")
VITE_FIREBASE_AUTH_DOMAIN=

# Your Firebase project ID
VITE_FIREBASE_PROJECT_ID=

# Your Firebase storage bucket URL (e.g., "my-project.appspot.com")
VITE_FIREBASE_STORAGE_BUCKET=

# Your Firebase Cloud Messaging sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Your Firebase app ID
VITE_FIREBASE_APP_ID=

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — External API Keys
# ═══════════════════════════════════════════════════════════════
# DeepSeek API key for AI-powered DM assistant features.
# Get one at https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=

# Spotify integration for campaign soundtrack features.
# Create an app at https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
# DEVELOPMENT — Local Firebase Emulators
# ═══════════════════════════════════════════════════════════════
# Set to 'true' to connect to local Firebase emulators instead of
# production Firebase. Requires the Firebase CLI and emulators running.
VITE_USE_EMULATORS=false
