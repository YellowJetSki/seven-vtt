rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campaign Documents ──────────────────────────────────
    // OPEN ACCESS (auth-free):
    // Auth is handled at the app level — players authenticate via name
    // matching, DM authenticates via env-variable comparison.
    // Since the DM owns this Firebase project, writes come only from
    // their browser. Players need read access to see live updates
    // (battle maps, session state, character sheets) without having
    // a Firebase Auth account.
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Live Session Documents ──────────────────────────────
    // Real-time combat & session state. Both DM and players read/write.
    match /liveSessions/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Homebrew Documents ──────────────────────────────────
    // Homebrew library per campaign. Both DM and players read.
    match /homebrew/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
