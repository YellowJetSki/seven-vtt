rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campaign Documents ──────────────────────────────────
    // AUTH-REQUIRED ACCESS:
    //   - Write: Only authenticated DM (request.auth.token.role == "dm")
    //   - Read: Any authenticated user (request.auth != null)
    // This protects campaign data while allowing players to view live state.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == "dm";
    }

    // ── Live Session Documents ──────────────────────────────
    // Real-time combat & session state.
    match /liveSessions/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == "dm";
    }

    // ── Homebrew Documents ──────────────────────────────────
    match /homebrew/{campaignId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == "dm";
    }

    // ── Deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
