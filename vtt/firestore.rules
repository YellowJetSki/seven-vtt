rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDm() {
      return isAuthenticated()
        && request.auth.token.role == "dm";
    }

    function isDmOrFirebaseUser() {
      return isAuthenticated()
        && (request.auth.token.role == "dm"
         || request.auth.token.role == "firebase_user");
    }

    function isPlayer() {
      return isAuthenticated()
        && request.auth.token.role == "player";
    }

    function getCharId() {
      // Players are identified by their Firebase UID matching their character ID
      return request.auth.uid;
    }

    function isOwnCharacter(charId: string) {
      return isAuthenticated()
        && request.auth.token.role == "player"
        && request.auth.uid == charId;
    }

    function isPlayerUpdatingOwnFields() {
      // Players may only update specific fields on their own character
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let allowedFields = [
        "hitPoints", "deathSaves", "conditions",
        "temporaryHitPoints", "experiencePoints",
        "inspiration", "currency", "inventory",
        "characterNotes", "equipment"
      ];
      return affected.hasOnly(allowedFields);
    }

    function isDmOrOwnCharacter(charId: string) {
      return isDm() || isOwnCharacter(charId);
    }

    // ═══════════════════════════════════════════════════════════
    //  CAMPAIGN COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /campaigns/{campaignId} {

      // ── Campaign Metadata ──────────────────────────────────
      // DM: full CRUD. Authenticated users: read-only.
      allow read: if isAuthenticated();
      allow create: if isDm();
      allow update: if isDm();
      allow delete: if isDm();

      // ── Characters Subcollection ───────────────────────────
      // DM: full CRUD on all character documents.
      // Player: read all, write only their OWN character (by UID match),
      //         and only specific gameplay fields (HP, XP, currency, etc.)
      match /characters/{charId} {
        allow read: if isAuthenticated();
        allow create: if isDm();
        allow update: if isAuthenticated()
          && (isDm()
            || (isPlayer()
              && charId == getCharId()
              && isPlayerUpdatingOwnFields()));
        allow delete: if isDm();
      }

      // ── Enemies Subcollection ──────────────────────────────
      // DM: full CRUD. Players: read-only.
      match /enemies/{enemyId} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }

      // ── Encounters Subcollection ───────────────────────────
      // DM: full CRUD. Players: read-only.
      match /encounters/{encounterId} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }

      // ── Maps Subcollection ─────────────────────────────────
      // DM: full CRUD. Players: read-only.
      match /maps/{mapId} {
        allow read: if isAuthenticated();
        allow write: if isDm();

        // Map tokens nested under maps
        match /tokens/{tokenId} {
          allow read: if isAuthenticated();
          allow write: if isDm();
        }
      }

      // ── Maps/Subcollections (legacy flat path) ─────────────
      // DM: full CRUD. Players: read-only.
      match /maps/{mapId}/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }

      // ── Journal Subcollection ──────────────────────────────
      // DM: full CRUD. Players: read-only.
      match /journal/{entryId} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }

      // ── Sessions Subcollection ─────────────────────────────
      // DM: full CRUD. Players: read-only.
      match /sessions/{sessionId} {
        allow read: if isAuthenticated();
        allow write: if isDm();

        // Session combatants nested under sessions
        match /combatants/{combatantId} {
          allow read: if isAuthenticated();
          allow write: if isDm();
        }
      }

      // ── Sessions/Subcollections (legacy flat path) ─────────
      match /sessions/{sessionId}/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }

      // ── Combat Log Subcollection ──────────────────────────
      match /combatLog/{logEntryId} {
        allow read: if isAuthenticated();
        allow create: if isDm();
        allow update, delete: if isDm();
      }

      // ── Catch-all for any other campaign subcollections ────
      // Prevents accidental data leaks from future subcollections
      match /{document=**} {
        allow read: if isAuthenticated();
        allow write: if isDm();
      }
    }

    // ═══════════════════════════════════════════════════════════
    //  HOMEBREW COLLECTIONS
    // ═══════════════════════════════════════════════════════════

    match /homebrew/{campaignId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isDm();
    }

    // ═══════════════════════════════════════════════════════════
    //  LIVE SESSIONS (Player Sync Bridge)
    // ═══════════════════════════════════════════════════════════

    match /liveSessions/{campaignId}/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isDm();
    }

    // ═══════════════════════════════════════════════════════════
    //  INSTALLABLE AUTH (Custom Claims Management)
    //  Allows the DM to create player auth accounts
    // ═══════════════════════════════════════════════════════════

    match /_auth/{userId} {
      allow read, write: if isDm();
    }

    // ═══════════════════════════════════════════════════════════
    //  CATCH-ALL DENY
    //  Any path not explicitly listed above is denied.
    // ═══════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
