rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campaign & ALL Subcollections ────────────────────────
    // Uses recursive wildcard {document=**} to cover:
    //   campaigns/{id}                          (metadata)
    //   campaigns/{id}/characters/{charId}      (PCs)
    //   campaigns/{id}/enemies/{enemyId}        (enemy templates)
    //   campaigns/{id}/encounters/{encId}       (encounter defs)
    //   campaigns/{id}/maps/{mapId}             (map config)
    //   campaigns/{id}/maps/{mapId}/tokens/{t}  (map tokens)
    //   campaigns/{id}/journal/{entryId}        (journal entries)
    //   campaigns/{id}/sessions/{sessionId}     (session state)
    //   campaigns/{id}/sessions/{sid}/combatants/{c} (live combatants)
    //   campaigns/{id}/combatLog/{logId}        (combat log)
    //
    // Write: Only authenticated DM (custom claim role == "dm")
    // Read:  Any authenticated user (DM or anonymous player)
    match /campaigns/{campaignId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == "dm";
    }

    // ── Homebrew & ALL Subcollections ────────────────────────
    // Covers: homebrew/{campaignId}/items/{itemId}
    //         homebrew/{campaignId}/spells/{spellId}
    //         homebrew/{campaignId}/feats/{featId}
    match /homebrew/{campaignId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == "dm";
    }

    // ── Deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
